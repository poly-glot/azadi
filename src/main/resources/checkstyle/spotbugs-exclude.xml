<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude DTOs (records) -->
    <Match>
        <Package name="~com\.azadi\..*\.dto"/>
    </Match>

    <!-- Exclude config classes -->
    <Match>
        <Package name="com.azadi.config"/>
    </Match>

    <!-- Exclude application entry point -->
    <Match>
        <Class name="com.azadi.AzadiApplication"/>
    </Match>

    <!-- Exclude seed data -->
    <Match>
        <Package name="com.azadi.seed"/>
    </Match>

    <!-- Mutable fields exposed via getters in Datastore entities - required by SDK -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Or>
            <Class name="com.azadi.agreement.Agreement"/>
            <Class name="com.azadi.auth.Customer"/>
            <Class name="com.azadi.payment.PaymentRecord"/>
            <Class name="com.azadi.bank.BankDetails"/>
            <Class name="com.azadi.document.Document"/>
            <Class name="com.azadi.audit.AuditEvent"/>
            <Class name="com.azadi.settlement.SettlementFigure"/>
            <Class name="com.azadi.statement.StatementRequest"/>
        </Or>
    </Match>

    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="com.azadi.agreement.Agreement"/>
            <Class name="com.azadi.auth.Customer"/>
            <Class name="com.azadi.payment.PaymentRecord"/>
            <Class name="com.azadi.bank.BankDetails"/>
            <Class name="com.azadi.document.Document"/>
            <Class name="com.azadi.audit.AuditEvent"/>
            <Class name="com.azadi.settlement.SettlementFigure"/>
            <Class name="com.azadi.statement.StatementRequest"/>
        </Or>
    </Match>

    <!-- Spring-managed constructor injection: beans are singletons, not externally mutable -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="com.azadi.audit.AuditService"/>
            <Class name="com.azadi.auth.AzadiAuthenticationProvider"/>
            <Class name="com.azadi.email.EmailService"/>
            <Class name="com.azadi.payment.StripePaymentService"/>
        </Or>
    </Match>

    <!-- Email templates use \n for platform-consistent line endings in HTML email -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
        <Package name="com.azadi.email.templates"/>
    </Match>

    <!-- Serialization not needed for Spring beans -->
    <Match>
        <Bug pattern="SE_BAD_FIELD"/>
    </Match>
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- Unconfirmed casts in webhook handler - Stripe SDK types -->
    <Match>
        <Bug pattern="BC_UNCONFIRMED_CAST"/>
        <Class name="com.azadi.payment.PaymentController"/>
    </Match>

    <!-- Spring CGLIB proxies -->
    <Match>
        <Class name="~.*\$\$SpringCGLIB\$\$.*"/>
    </Match>
</FindBugsFilter>
