{
  "name": "azadi-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp -r src/img dist/assets/img",
    "lint": "eslint src/js/",
    "lint:fix": "eslint src/js/ --fix",
    "format": "prettier --write 'src/**/*.{css,js,html}'",
    "format:check": "prettier --check 'src/**/*.{css,js,html}'"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "autoprefixer": "^10.4.0",
    "cssnano": "^7.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "vite": "^6.0.0"
  },
  "browserslist": [
    "last 2 versions"
  ]
}
