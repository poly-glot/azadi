{% extends "layout.njk" %}

{% block content_public %}
<div class="o-band o-band--fullscreen" style="background-image: url(/assets/img/background.jpg)">
  <div class="o-wrapper">
    <div class="c-dialog u-small">
      <div class="c-dialog__inner">
        <h3 class="c-dialog__heading u-margin-bottom-small u-condense">
          Welcome to<br>Azadi Financial Services
        </h3>

        <p>Please enter your details in the fields below to log into your Azadi Financial Services customer account.</p>

        <form method="post" action="/login" id="login-form">
          <div class="c-form__field">
            <label for="dob-day" class="c-form__label">Date of birth<span class="u-color-default">*</span></label>
            <div class="c-input-group">
              <select name="dobDay" id="dob-day" class="c-select" required>
                <option value="" disabled selected>Day</option>
                {% for d in range(1, 32) %}
                <option value="{{ d }}">{{ d }}</option>
                {% endfor %}
              </select>
              <select name="dobMonth" id="dob-month" class="c-select" required>
                <option value="" disabled selected>Month</option>
                <option value="1">January</option>
                <option value="2">February</option>
                <option value="3">March</option>
                <option value="4">April</option>
                <option value="5">May</option>
                <option value="6">June</option>
                <option value="7">July</option>
                <option value="8">August</option>
                <option value="9">September</option>
                <option value="10">October</option>
                <option value="11">November</option>
                <option value="12">December</option>
              </select>
              <select name="dobYear" id="dob-year" class="c-select" required>
                <option value="" disabled selected>Year</option>
                {% for y in range(2008, 1939, -1) %}
                <option value="{{ y }}">{{ y }}</option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="c-form__field">
            <label for="postcode" class="c-form__label">Postcode<span class="u-color-error">*</span></label>
            <input type="text" name="postcode" id="postcode" class="c-input c-input--small" placeholder="Postcode" required>
          </div>

          <div class="c-form__field">
            <label for="agreement" class="c-form__label">Agreement Number<span class="u-color-default">*</span></label>
            <input type="text" name="agreementNumber" id="agreement" class="c-input" placeholder="Agreement number" required inputmode="numeric">
          </div>

          <div class="c-form__field">
            <label class="c-option">
              <input type="checkbox" name="rememberAgreement" class="c-option__input" value="1">
              <span class="c-option__label">Remember my agreement number</span>
            </label>
          </div>

          <div class="c-form__actions">
            <button type="submit" class="c-button">Login</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}
