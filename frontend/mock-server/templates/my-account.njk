{% extends "layout.njk" %}

{% block content %}
<h1 class="u-condense" style="font-size: var(--font-size-2xl); text-transform: capitalize;">My Account</h1>

<div style="border-block-end: 2px solid var(--border-color); padding-block-end: var(--spacing-small); margin-block-end: var(--spacing-medium);">
  <p class="u-h5 u-margin-bottom-none">
    <strong>Agreement number: </strong> {{ agreement.number }}
  </p>
</div>

<div class="o-layout o-layout--2col">
  <!-- Account Details -->
  <div>
    <details class="c-accordion c-accordion--section" open>
      <summary class="c-accordion__summary">
        <span class="c-accordion__label">Account Details</span>
        <span class="c-accordion__indicator" aria-hidden="true">+</span>
      </summary>
      <div class="c-accordion__panel c-accordion__panel--shadow">
        <div class="c-table">
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Current balance:</div>
            <div class="c-table__column">{{ agreement.currentBalance }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Original agreement term:</div>
            <div class="c-table__column">{{ agreement.term }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">APR %:</div>
            <div class="c-table__column">{{ agreement.apr }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Contract Mileage:</div>
            <div class="c-table__column">{{ agreement.contractMileage }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Excess Price per Mile:</div>
            <div class="c-table__column">{{ agreement.excessPricePerMile }}</div>
          </div>
        </div>
        <div style="padding: var(--spacing-small) var(--spacing-medium);">
          <p><strong>Model:</strong> {{ agreement.vehicleModel }}</p>
          <p class="u-margin-bottom-none"><strong>Registration Number:</strong> {{ agreement.registrationNumber }}</p>
        </div>
      </div>
    </details>
  </div>

  <!-- Payment Details -->
  <div>
    <details class="c-accordion c-accordion--section" open>
      <summary class="c-accordion__summary">
        <span class="c-accordion__label">Payment Details</span>
        <span class="c-accordion__indicator" aria-hidden="true">+</span>
      </summary>
      <div class="c-accordion__panel c-accordion__panel--shadow">
        <div class="c-table">
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Last payment received:</div>
            <div class="c-table__column">{{ agreement.lastPaymentAmount }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Date received:</div>
            <div class="c-table__column">{{ agreement.lastPaymentDate }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Amount of next payment:</div>
            <div class="c-table__column">{{ agreement.nextPaymentAmount }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Date next payment is due:</div>
            <div class="c-table__column">{{ agreement.nextPaymentDate }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Payments remaining:</div>
            <div class="c-table__column">{{ agreement.paymentsRemaining }}</div>
          </div>
          <div class="c-table__row">
            <div class="c-table__column c-table__column--label">Date of final payment:</div>
            <div class="c-table__column">{{ agreement.finalPaymentDate }}</div>
          </div>
        </div>
      </div>
    </details>
  </div>
</div>
{% endblock %}
